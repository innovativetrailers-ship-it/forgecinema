{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",

  "functions": {
    "src/app/api/upload/**": { "maxDuration": 120 },
    "src/app/api/jobs/create/route": { "maxDuration": 60 },
    "src/app/api/jobs/[jobId]/stream/route": { "maxDuration": 300 },
    "src/app/api/studio/director/route": { "maxDuration": 120 },
    "src/app/api/studio/continuity/route": { "maxDuration": 90 },
    "src/app/api/studio/storyboard/route": { "maxDuration": 90 },
    "src/app/api/timeline/render/route": { "maxDuration": 300 },
    "src/app/api/cgi/insert/route": { "maxDuration": 180 },
    "src/app/api/audio/**": { "maxDuration": 120 },
    "src/app/api/webhooks/**": { "maxDuration": 30 }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-user-id, x-user-role" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ],

  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },

  "crons": [
    {
      "path": "/api/cron/cleanup-jobs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-rlhf",
      "schedule": "0 2 * * 0"
    }
  ]
}
