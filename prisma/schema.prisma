generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FREE
  PRO
  STUDIO
  ADMIN
}

enum JobType {
  GENERATE
  REPAINT
  RELIGHT
  UPSCALE
  EXPORT
  LORA_TRAIN
  LIPSYNC
  AUTO_SOCIAL
  TRANSCRIBE
  CGI_INSERT
  AVATAR
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETE
  FAILED
  CANCELLED
  NEEDS_ATTENTION
}

enum HoldStatus {
  ACTIVE
  SETTLED
  REFUNDED
}

enum StudioSceneStatus {
  PENDING
  GENERATING
  GENERATED
  FAILED
}

enum StudioClipStatus {
  PENDING
  AWAITING_DIRECTION
  GENERATING
  COMPLETED
  FAILED
  MANUAL
}

enum AnchorSource {
  AUTO
  MANUAL
  KEYFRAME
  NONE
}

enum LocationSource {
  MAPILLARY
  CESIUM
  OSM_FALLBACK
  USER_UPLOAD
}

enum LoraStatus {
  PENDING
  TRAINING
  READY
  FAILED
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  avatarUrl          String?
  passwordHash       String?
  role               UserRole  @default(FREE)
  creditBalance      Int       @default(50)
  heldCredits        Int       @default(0)
  totalGenerated     Int       @default(0)
  subscriptionTier     String    @default("free")
  subscriptionStatus String    @default("trial")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  projects        Project[]
  creditTxns      CreditTransaction[]
  creditHolds     CreditHold[]
  renderJobs      RenderJob[]
  trainingData    TrainingData[]
  rlhfLogs        RLHFLog[]
  accounts        Account[]
  sessions        Session[]
  avatars         Avatar[]
  reviewLinks     ReviewLink[]
  brandKits         BrandKit[]
  filmProjects      FilmProject[]
  seriesProjects    SeriesProject[]
  clonedVoices      ClonedVoice[]
  stripeCustomer    StripeCustomer?
  stripeDeposits    StripeDeposit[]
  socialConnections SocialConnection[]
  vendorUsage     VendorUsageLog[]
  locationPlates  LocationPlate[]
  episodicMemories EpisodicMemory[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id              String    @id @default(cuid())
  userId          String
  title           String    @default("Untitled Project")
  description     String?
  thumbnailUrl    String?
  timelineJson    Json?
  durationSeconds Float     @default(0)
  fps             Int       @default(24)
  resolution      String    @default("1920x1080")
  status          String    @default("draft")
  isPublic        Boolean   @default(false)
  musicUrl        String?
  ambienceUrl     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  renderJobs      RenderJob[]
  vaultChars      VaultCharacter[]
  vaultLocations  VaultLocation[]
  mediaBins       MediaBin[]
  studioScenes    StudioScene[]
  audioTracks     AudioTrack[]

  @@index([userId])
}

enum AudioType {
  DIALOGUE
  MUSIC
  AMBIENCE
  SFX
  CUSTOM
}

enum AudioProvider {
  ELEVENLABS
  SUNO
  UPLOAD
}

enum AudioStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

model AudioTrack {
  id                  String        @id @default(cuid())
  projectId           String
  type                AudioType
  provider            AudioProvider @default(ELEVENLABS)
  status              AudioStatus   @default(PENDING)
  prompt              String?       @db.Text
  voiceId             String?
  sunoStyle           String?
  sunoLyrics          String?       @db.Text
  instrumental        Boolean       @default(true)
  shotPlanId          String?
  sceneNumber         Int?
  startSec            Float?
  volumeDb            Float         @default(0)
  muted               Boolean       @default(false)
  locked              Boolean       @default(false)
  fadeInMs            Int           @default(0)
  fadeOutMs           Int           @default(0)
  duckUnderDialogue   Boolean       @default(false)
  durationWarning     Boolean       @default(false)
  url                 String?
  durationMs          Int?
  version             Int           @default(1)
  prevUrl             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  project             Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@index([shotPlanId])
}

model StudioScene {
  id              String            @id @default(cuid())
  projectId       String
  sceneNumber     Int
  title           String?
  transitionFrame String?
  status          StudioSceneStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips           StudioClip[]

  @@unique([projectId, sceneNumber])
  @@index([projectId])
}

model StudioClip {
  id              String           @id @default(cuid())
  sceneId         String
  clipNumber      Int
  prompt          String           @db.Text
  originalPrompt  String?          @db.Text
  duration        Int
  aspectRatio     String           @default("16:9")
  assignedModel   String?
  status          StudioClipStatus @default(PENDING)
  videoUrl        String?
  lastFrame       String?
  keyframeUrl     String?
  scriptBeatId    String?
  anchorPolicy    String           @default("none")
  anchorFrameUrl  String?
  anchorSource    AnchorSource     @default(NONE)
  directionNotes  String?          @db.Text
  modelOverride   String?
  generatingAt    DateTime?
  lipSyncEnabled  Boolean          @default(true)
  lipSyncModel    String?
  rawVideoUrl     String?
  manualVideo     Boolean          @default(false)
  estimatedCost   Int              @default(0)
  scene           StudioScene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([sceneId, clipNumber])
  @@index([sceneId])
}

model VaultCharacter {
  id              String      @id @default(cuid())
  projectId       String
  name            String
  referenceUrls   String[]
  refProfile      String?
  ref3Quarter     String?
  refBack         String?
  faceEmbedding   Json?
  bodyEmbedding   Json?
  appearance      Json?
  behavioralPrompt String?
  loraModelId     String?
  loraStatus      LoraStatus  @default(PENDING)
  modelFamily     String?
  voiceId         String?
  voiceProvider   String?
  motionRefUrl    String?
  renderCount     Int         @default(0)
  styleJson       Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project         Project     @relation(fields: [projectId], references: [id])
  wardrobe        WardrobeItem[]

  @@index([projectId])
}

model WardrobeItem {
  id           String         @id @default(cuid())
  characterId  String
  region       String
  prompt       String
  refImageUrl  String
  lockedHash   String
  appliedAt    DateTime       @default(now())
  character    VaultCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

model VaultLocation {
  id               String          @id @default(cuid())
  projectId        String
  name             String
  source           LocationSource
  lat              Float?
  lng              Float?
  hdriUrl          String?
  depthMapUrl      String?
  referenceUrls    String[]
  metaJson         Json?
  generativePrompt String?
  createdAt        DateTime        @default(now())

  project          Project         @relation(fields: [projectId], references: [id])
}

model RenderJob {
  id              String      @id @default(cuid())
  userId          String
  projectId       String?
  type            JobType     @default(GENERATE)
  status          JobStatus   @default(QUEUED)
  priority        Int         @default(1)
  modelUsed       String?
  creditsCharged  Int         @default(0)
  inputPayload    Json        @default("{}")
  outputUrl       String?
  outputUrls      String[]
  proxyUrl        String?
  errorMessage    String?
  progressPct     Int         @default(0)
  processingMs    Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?
  // Orchestration V2 fields
  prompt          String?
  duration        Int         @default(10)
  mode            String      @default("simple")
  statusMessage   String?
  phase           String?     // patient_zero | breakdown | routing | generating | stitching
  etaSeconds      Int?        // estimated seconds remaining (updated live by worker)
  metadata        Json?

  user                User                @relation(fields: [userId], references: [id])
  project             Project?            @relation(fields: [projectId], references: [id])
  creditHold          CreditHold?
  segmentCheckpoints  SegmentCheckpoint[]
  segmentLedgers      SegmentLedger[]

  @@index([userId, status])
  @@index([projectId])
}

model CreditHold {
  id          String     @id @default(cuid())
  userId      String
  jobId       String     @unique
  amountHeld  Int
  amountUsed  Int        @default(0)
  status      HoldStatus @default(ACTIVE)
  budgetCap   Int?
  createdAt   DateTime   @default(now())
  settledAt   DateTime?

  user        User       @relation(fields: [userId], references: [id])
  job         RenderJob  @relation(fields: [jobId], references: [id])

  @@index([userId])
}

model SegmentCheckpoint {
  id          String   @id @default(cuid())
  jobId       String
  segmentId   String
  shotId      Int
  videoUrl    String
  modelUsed   String
  cost        Int
  qaPassed    Boolean  @default(true)
  anchorFrame String?
  createdAt   DateTime @default(now())

  job         RenderJob @relation(fields: [jobId], references: [id])

  @@unique([jobId, segmentId])
  @@index([jobId])
}

model SegmentLedger {
  id        String   @id @default(cuid())
  jobId     String
  segmentId String
  cost      Int
  createdAt DateTime @default(now())

  job       RenderJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  type         String?
  description  String
  jobId        String?
  stripeId     String?
  balanceAfter Int      @default(0)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model TrainingData {
  id                  String    @id @default(cuid())
  userId              String
  type                String
  originalUrl         String?
  instruction         String?
  regeneratedUrl      String?
  promptVariants      Json?
  selectedVariantIdx  Int?
  metadata            Json?
  isProcessed         Boolean   @default(false)
  createdAt           DateTime  @default(now())

  user                User      @relation(fields: [userId], references: [id])

  @@index([isProcessed])
}

model RLHFLog {
  id              String    @id @default(cuid())
  userId          String
  sessionId       String
  promptText      String
  modelOptions    Json
  selectedModel   String
  selectedIdx     Int
  context         Json?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id])
}

model ApiUsageLog {
  id          String    @id @default(cuid())
  provider    String
  model       String
  userId      String?
  jobId       String?
  costCents   Float
  latencyMs   Int
  success     Boolean
  createdAt   DateTime  @default(now())

  @@index([provider, createdAt])
}

model Avatar {
  id           String   @id @default(cuid())
  userId       String
  name         String
  type         String   // 'instant' | 'stock' | 'custom'
  videoUrl     String
  thumbnailUrl String
  voiceId      String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ReviewLink {
  id            String          @id @default(cuid())
  projectId     String
  userId        String
  token         String          @unique @default(cuid())
  title         String
  status        String          @default("pending")
  expiresAt     DateTime?
  allowDownload Boolean         @default(false)
  comments      ReviewComment[]
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
}

model ReviewComment {
  id             String     @id @default(cuid())
  reviewLinkId   String
  authorName     String
  authorEmail    String
  timecode       Float
  clipId         String?
  text           String
  annotationData Json?
  resolved       Boolean    @default(false)
  createdAt      DateTime   @default(now())

  link           ReviewLink @relation(fields: [reviewLinkId], references: [id])

  @@index([reviewLinkId])
}

model BrandKit {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  primaryColor       String
  secondaryColor     String
  accentColor        String
  fontFamily         String
  logoUrl            String?
  introClipUrl       String?
  outroClipUrl       String?
  lowerThirdStyle    Json
  watermarkUrl       String?
  watermarkPosition  String   @default("bottom-right")
  watermarkOpacity   Float    @default(0.6)
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())

  user               User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── CASTING SYSTEM ─────────────────────────────────────────

model CastMember {
  id                  String    @id @default(cuid())
  projectId           String
  name                String
  role                String    // 'lead' | 'supporting' | 'featured' | 'background' | 'voice_only'
  faceReferenceUrls   String[]
  loraModelId         String?
  loraStatus          String    @default("pending")
  lockedModelFamily   String?
  baseAppearance      Json
  costumesByScene     Json      @default("{}")
  makeupState         Json
  makeupByScene       Json      @default("{}")
  voiceId             String?
  voiceProvider       String    @default("elevenlabs")
  voiceCharacteristics Json     @default("{}")
  appearsInScenes     String[]
  totalScreenTime     Float     @default(0)
  relationshipsTo     Json      @default("[]")
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([projectId])
}

// ── FILM MODE ──────────────────────────────────────────────

enum FilmType {
  FEATURE_FILM
  SHORT_FILM
  DOCUMENTARY
  MUSIC_VIDEO
  COMMERCIAL
  EXPERIMENTAL
}

enum FilmStatus {
  DEVELOPMENT
  PRE_PRODUCTION
  PRODUCTION
  POST_PRODUCTION
  COMPLETE
  RELEASED
}

model FilmProject {
  id               String          @id @default(cuid())
  userId           String
  title            String
  type             FilmType
  logline          String?
  synopsis         String?
  genre            String[]
  targetRuntime    Int
  rating           String?
  status           FilmStatus      @default(DEVELOPMENT)
  colourPalette    Json?
  cinematicStyle   String?
  aspectRatio      String          @default("2.39:1")
  soundDesignNotes String?
  musicStyle       String?
  finalVideoUrl    String?
  exportStatus     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id])
  acts             Act[]
  cast             FilmCastMember[]
  locations        FilmLocation[]

  @@index([userId])
}

model Act {
  id            String     @id @default(cuid())
  filmProjectId String
  number        Int
  title         String?
  description   String?

  film          FilmProject @relation(fields: [filmProjectId], references: [id])
  sequences     Sequence[]

  @@index([filmProjectId])
}

model Sequence {
  id          String      @id @default(cuid())
  actId       String
  title       String
  description String?

  act         Act         @relation(fields: [actId], references: [id])
  scenes      FilmScene[]

  @@index([actId])
}

model FilmScene {
  id              String   @id @default(cuid())
  sequenceId      String
  sceneNumber     String
  intExt          String
  location        String
  timeOfDay       String
  heading         String
  actionLines     String
  dialogue        Json
  characterIds    String[]
  locationId      String?
  shotList        Json?
  generatedClips  String[]
  status          String   @default("scripted")
  productionNotes String?

  sequence        Sequence @relation(fields: [sequenceId], references: [id])

  @@index([sequenceId])
}

model FilmCastMember {
  id               String      @id @default(cuid())
  filmProjectId    String
  vaultCharacterId String
  characterName    String
  role             String
  actorNotes       String?

  film             FilmProject @relation(fields: [filmProjectId], references: [id])

  @@index([filmProjectId])
}

model FilmLocation {
  id              String      @id @default(cuid())
  filmProjectId   String
  vaultLocationId String?
  name            String
  description     String

  film            FilmProject @relation(fields: [filmProjectId], references: [id])

  @@index([filmProjectId])
}

// ── SERIES MODE ────────────────────────────────────────────

enum SeriesType {
  TV_DRAMA
  TV_COMEDY
  WEB_SERIES
  SOCIAL_SERIES
  DOCUMENTARY_SERIES
  ANTHOLOGY
}

model SeriesProject {
  id                   String     @id @default(cuid())
  userId               String
  title                String
  type                 SeriesType
  platform             String
  episodeFormat        Json
  seriesBible          Json
  recurringCastIds     String[]
  recurringLocationIds String[]
  status               String     @default("development")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  user                 User       @relation(fields: [userId], references: [id])
  seasons              Season[]

  @@index([userId])
}

model Season {
  id           String        @id @default(cuid())
  seriesId     String
  seasonNumber Int
  title        String?
  seasonArc    String?
  episodeCount Int           @default(0)
  status       String        @default("planned")

  series       SeriesProject @relation(fields: [seriesId], references: [id])
  episodes     Episode[]

  @@index([seriesId])
}

model Episode {
  id             String   @id @default(cuid())
  seasonId       String
  episodeNumber  Int
  title          String
  logline        String?
  previouslyOn   String?
  coldOpen       String?
  actBreaks      Json
  sceneIds       String[]
  tags           String[]
  targetRuntime  Int
  finalVideoUrl  String?
  status         String   @default("planned")

  season         Season   @relation(fields: [seasonId], references: [id])

  @@index([seasonId])
}

// ── MEDIA BIN (project asset management) ──────────────────
model MediaBin {
  id        String         @id @default(cuid())
  projectId String
  name      String
  colour    String         @default("#00e5c8")
  sortOrder Int            @default(0)
  entries   BinClipEntry[]
  project   Project        @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model BinClipEntry {
  id              String    @id @default(cuid())
  binId           String
  clipUrl         String
  proxyUrl        String?
  name            String
  durationSeconds Float?
  thumbnailUrl    String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  bin             MediaBin  @relation(fields: [binId], references: [id])

  @@index([binId])
}

// ── ROUTING TELEMETRY (technical domain) ──────────────────
model RoutingDecision {
  id             String   @id @default(cuid())
  sceneCategory  String
  assignedEngine String
  tier           String
  qualityScore   Float?
  neededRepaint  Boolean  @default(false)
  creditsCost    Int
  generationMs   Int?
  segmentCount   Int      @default(1)
  createdAt      DateTime @default(now())

  @@index([sceneCategory, assignedEngine])
}

model EnginePerformanceLog {
  id            String   @id @default(cuid())
  engineId      String
  sceneCategory String
  tier          String
  latencyMs     Int
  qualityScore  Float
  costCents     Float
  success       Boolean
  errorType     String?
  createdAt     DateTime @default(now())

  @@index([engineId, createdAt])
}

model BlendQualityLog {
  id            String   @id @default(cuid())
  clipId        String
  engineIds     String[]
  stitchCount   Int
  qualityScore  Float
  repaintNeeded Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([clipId])
}

// ── INTELLIGENCE PIPELINE ──────────────────────────────────
model ProbeResult {
  id             String   @id @default(cuid())
  probeId        String
  category       String
  engineId       String
  engineVersion  String
  prompt         String
  videoUrl       String
  qualityScore   Float
  issues         String[]
  strengths      String[]
  assessmentJson Json
  tierUsed       String
  generationMs   Int
  createdAt      DateTime @default(now())

  @@index([engineId, category])
}

model ModelReport {
  id             String   @id @default(cuid())
  engineId       String
  engineVersion  String
  reportDate     DateTime
  generatedBy    String
  reportJson     Json
  probeCount     Int
  isDelta        Boolean  @default(false)
  previousReport String?
  createdAt      DateTime @default(now())

  @@index([engineId, reportDate])
}

model ModelUpdate {
  id                       String   @id @default(cuid())
  engineId                 String
  previousVersion          String
  newVersion               String
  detectedAt               DateTime
  probesRun                Int      @default(0)
  trainingSignalsExtracted Int      @default(0)
  routingUpdated           Boolean  @default(false)

  @@index([engineId])
}

/// FAL OpenAPI input constraints — cached per endpoint (schema-sync engine).
model ModelConstraint {
  endpoint   String   @id
  json       Json
  schemaHash String
  fetchedAt  DateTime
}

model TrainingSignal {
  id                 String   @id @default(cuid())
  sourceEngine       String
  sourceVersion      String
  prompt             String
  videoUrl           String
  qualityScore       Float?
  failureDescription String?
  category           String
  signalType         String
  processed          Boolean  @default(false)
  ingestedAt         DateTime @default(now())

  @@index([processed, signalType])
}

model ClonedVoice {
  id          String   @id @default(cuid())
  userId      String
  voiceId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, voiceId])
  @@index([userId])
}

model StripeCustomer {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String   @unique
  stripeBalanceCents   Int      @default(0)
  lifetimeDepositCents Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StripeDeposit {
  id                    String   @id @default(cuid())
  userId                String
  stripeCustomerId      String
  paymentIntentId       String   @unique
  amountCents           Int
  platformFeeCents      Int
  vendorAllocationCents Int
  status                String   @default("pending")
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id])
}

model VendorUsageLog {
  id         String   @id @default(cuid())
  userId     String
  vendor     String
  operation  String
  costUSD    Float
  creditCost Int
  requestId  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([vendor])
  @@index([createdAt])
}

model SocialConnection {
  id           String   @id @default(cuid())
  userId       String
  platform     String   // tiktok | instagram | youtube
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
  @@index([userId])
}


model ConflictLog {
  id          String    @id @default(cuid())
  projectId   String
  type        String
  userId1     String
  userId2     String
  clipId      String
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime  @default(now())

  @@index([projectId, resolvedAt])
  @@index([projectId, createdAt])
}

model ShoppableEmbed {
  id        String   @id @default(cuid())
  projectId String
  videoUrl  String
  config    Json
  embedId   String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([embedId])
}

model BranchingEmbed {
  id        String   @id @default(cuid())
  projectId String
  title     String   @default("")
  config    Json
  embedId   String   @unique @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([embedId])
}

model LocationPlate {
  id          String   @id @default(cuid())
  userId      String
  imageUrl    String
  sourceUrl   String
  type        String   // 'street' | 'satellite'
  lat         Float?
  lng         Float?
  displayName String?
  city        String?
  country     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model ClipComment {
  id         String       @id @default(cuid())
  projectId  String
  clipId     String
  authorId   String
  timecode   Float
  text       String
  parentId   String?      // null = top-level; set = reply
  resolved   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  parent     ClipComment? @relation("CommentThread", fields: [parentId], references: [id])
  replies    ClipComment[] @relation("CommentThread")

  @@index([projectId, clipId])
  @@index([projectId, createdAt])
  @@index([parentId])
}

// ── Cognitive Director: CoALA memory stores ─────────────────────────────────
// Episodic memory: every creative decision + its outcome (vector RAG).
model EpisodicMemory {
  id           String   @id @default(cuid())
  userId       String
  projectId    String?
  kind         String // 'project' | 'scene' | 'routing_decision' | 'feedback'
  summary      String
  intent       Json?
  brief        Json?
  outcome      Json?
  embedding    Unsupported("vector(1024)")?
  importance   Float    @default(0.5) // 0-1, drives selective forgetting
  accessCount  Int      @default(0) // recency/frequency for decay
  lastAccessed DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([kind])
}

// Semantic memory: consolidated, generalised knowledge.
model SemanticMemory {
  id             String   @id @default(cuid())
  userId         String? // null = global knowledge; set = user-specific taste
  category       String // 'user_taste' | 'craft_rule' | 'model_insight' | 'genre_pattern'
  insight        String
  evidence       Json?
  confidence     Float    @default(0.5)
  embedding      Unsupported("vector(1024)")?
  reinforceCount Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([category])
}

// Procedural memory: learned model-routing policies.
model RoutingPolicy {
  id            String   @id @default(cuid())
  contentType   String
  model         String
  successRate   Float    @default(0.5) // rolling avg quality score 0-1
  sampleCount   Int      @default(0)
  avgGenSeconds Float    @default(60)
  lastUpdated   DateTime @default(now())

  @@unique([contentType, model])
  @@index([contentType])
}

// ── Cognitive enhancements ──────────────────────────────────────────────────
// Live performance matrix: real-time latency/cost/success with a circuit breaker.
model ModelPerformance {
  id               String   @id @default(cuid())
  model            String   @unique
  avgLatencyMs     Float    @default(60000)
  p95LatencyMs     Float    @default(120000)
  successRate      Float    @default(1.0) // last-N success ratio
  recentFailures   Int      @default(0) // consecutive failures (circuit breaker)
  costPer5sCredits Int      @default(10)
  status           String   @default("healthy") // healthy | degraded | down
  lastCheckedAt    DateTime @default(now())
  sampleCount      Int      @default(0)

  @@index([status])
}

// Implicit reward signals: learn from export vs regenerate, watch-complete, etc.
model RewardSignal {
  id          String   @id @default(cuid())
  userId      String
  jobId       String?
  model       String?
  contentType String?
  signal      String // 'export' | 'regenerate' | 'watch_complete' | 'discard' | 'thumbs_up' | 'thumbs_down'
  reward      Float
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([model])
}

// Lightweight knowledge graph: relational craft rules for multi-hop reasoning.
model CraftRule {
  id             String   @id @default(cuid())
  subject        String
  relation       String // 'pairs_with' | 'requires' | 'avoids'
  object         String
  confidence     Float    @default(0.6)
  source         String // 'learned' | 'seeded'
  reinforceCount Int      @default(1)
  createdAt      DateTime @default(now())

  @@unique([subject, relation, object])
  @@index([subject])
}
