# =============================================================================
# CINEMATIC FORGE V2.0 — Environment Variables
# Copy this file to .env.local and fill in all required values.
# =============================================================================

# ─── Authentication ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=                    # Required: random 32+ char secret
NEXTAUTH_URL=https://cinemaforge.io # Required: full URL of your deployment

GOOGLE_CLIENT_ID=                   # Required: Google OAuth client ID
GOOGLE_CLIENT_SECRET=               # Required: Google OAuth client secret

GITHUB_ID=                          # Optional: GitHub OAuth app ID
GITHUB_SECRET=                      # Optional: GitHub OAuth app secret

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/cinema   # Primary PostgreSQL DB
DB_PRODUCT=postgresql://...         # Product domain DB (optional isolated)
DB_TECHNICAL=postgresql://...       # Technical domain DB
DB_INTELLIGENCE=postgresql://...    # Intelligence domain DB
DB_MARKETING=postgresql://...       # Marketing domain DB

# ─── Cache / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379    # Required: primary Redis instance
REDIS_PRODUCT=redis://...           # Optional: isolated product namespace
REDIS_TECHNICAL=redis://...
REDIS_INTELLIGENCE=redis://...
REDIS_MARKETING=redis://...

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_BUCKET_NAME=cinema-media         # R2 bucket name
R2_ACCOUNT_ID=                      # Cloudflare account ID
R2_ACCESS_KEY_ID=                   # R2 access key ID
R2_SECRET_ACCESS_KEY=               # R2 secret access key
R2_REGION=auto                      # Always "auto" for R2
R2_PUBLIC_URL=https://media.cinemaforge.io  # Public CDN URL for R2
R2_RELEASES_BUCKET=forge                   # R2 bucket for installers (often same as R2_BUCKET_NAME)
R2_RELEASES_PREFIX=releases              # Prefix inside bucket (upload-releases.mjs layout)
DESKTOP_RELEASES_PREFIX=releases         # Alias read by releasesR2.ts
DESKTOP_RELEASES_PUBLIC_URL=https://releases.forgecinema.app
NEXT_PUBLIC_DESKTOP_RELEASES_URL=https://releases.forgecinema.app
# Until releases.forgecinema.app DNS is wired: ${R2_PUBLIC_URL}/releases

# ─── GitHub Actions (optional — sync via ./scripts/sync-github-secrets.sh) ───
# VERCEL_TOKEN=                     # vercel.com/account/tokens
# VERCEL_ORG_ID=                    # .vercel/repo.json → orgId
# VERCEL_PROJECT_ID=                # .vercel/repo.json → projects[0].id

# ─── AI Models — Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                          # Primary (PRODUCT domain)
ANTHROPIC_API_KEY_TECHNICAL=                # TECHNICAL domain
ANTHROPIC_API_KEY_INTELLIGENCE=             # INTELLIGENCE domain
ANTHROPIC_API_KEY_MARKETING=                # MARKETING domain

# ─── AI Models — Video Generation ────────────────────────────────────────────
KLING_API_KEY=                      # Kling video generation
SEEDANCE_API_KEY=                   # Seedance video generation
LUMA_API_KEY=                       # Luma Dream Machine
RUNWAY_API_KEY=                     # Runway Gen-3 Alpha
PIKA_API_KEY=                       # Pika Labs
MINIMAX_API_KEY=                    # Minimax video
HUNYUANVIDEO_API_KEY=               # HunyuanVideo
SORA_API_KEY=                       # OpenAI Sora
VEO3_API_KEY=                       # Google Veo 3

# ─── AI Models — Local/Self-hosted ────────────────────────────────────────────
LLAMA_SCOUT_ENDPOINT=http://localhost:8000  # Local vLLM server (Llama Scout)
MOCHI_ENDPOINT=http://localhost:8001        # Mochi inference endpoint

# ─── fal.ai ───────────────────────────────────────────────────────────────────
FAL_KEY=                            # fal.ai API key (object removal, enhancements)

# ─── E-commerce Integrations ─────────────────────────────────────────────────
SHOPIFY_API_KEY=                    # Shopify admin API key
SHOPIFY_API_PASSWORD=               # Shopify admin API password
SHOPIFY_STOREFRONT_TOKEN=           # Shopify Storefront Access Token (for cart)
WOOCOMMERCE_API_KEY=                # WooCommerce consumer key
WOOCOMMERCE_API_SECRET=             # WooCommerce consumer secret

# ─── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                  # Stripe secret key (sk_live_...)
STRIPE_PUBLIC_KEY=                  # Stripe publishable key (pk_live_...)
PAYPAL_CLIENT_ID=                   # PayPal client ID
PAYPAL_SECRET=                      # PayPal client secret

# ─── Communication Services ───────────────────────────────────────────────────
SENDGRID_API_KEY=                   # SendGrid (transactional email)
TWILIO_ACCOUNT_SID=                 # Twilio (SMS, optional)
TWILIO_AUTH_TOKEN=

# ─── Optional Services ────────────────────────────────────────────────────────
SUNO_API_KEY=                       # Suno AI (music generation, optional)

# ─── Public URLs ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cinemaforge.io  # Full app URL (used in embeds, QR codes)
NEXT_PUBLIC_LUMA_API_URL=https://api.luma.ai

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_EMOTION_LATTICE=true        # Enable Emotion Lattice analysis
FEATURE_OBJECT_REMOVAL=true         # Enable AI object removal
FEATURE_CAMERA_INGEST=true          # Enable wireless camera ingest
FEATURE_COLLAB=true                 # Enable real-time collaboration
FEATURE_SHOPPABLE=true              # Enable shoppable video exports
FEATURE_UNREAL_EXPORT=true          # Enable Unreal Engine export

# ─── Security ────────────────────────────────────────────────────────────────
CRON_SECRET=                        # Secret for cron job routes
WORKER_HEALTH_TOKEN=                # Token for worker health check routes

# ─── Monitoring & Logging ────────────────────────────────────────────────────
SENTRY_DSN=                         # Sentry error tracking DSN
LOG_LEVEL=info                      # Log level: debug | info | warn | error

# ─── Development ─────────────────────────────────────────────────────────────
NODE_ENV=development                # development | production
DEBUG=false                         # Enable verbose debug logging
