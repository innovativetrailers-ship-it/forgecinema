# ──────────────────────────────────────────────────────────────────────────────
# CINEMATIC FORGE — Environment Variables
# Copy to .env.local for local development. Set all marked REQUIRED on Vercel.
# ──────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # REQUIRED: production URL on Vercel

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
AUTH_SECRET=                                        # REQUIRED: openssl rand -base64 32
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=https://your-domain.vercel.app         # Production only
NEXTAUTH_SECRET=                                    # Same value as AUTH_SECRET

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                                   # REQUIRED
GOOGLE_CLIENT_SECRET=                               # REQUIRED

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/cinema?sslmode=require  # REQUIRED
DATABASE_TECHNICAL_URL=                             # Optional: telemetry DB
DATABASE_INTELLIGENCE_URL=                          # Optional: intelligence DB

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379        # REQUIRED

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=                                      # REQUIRED
R2_ACCESS_KEY_ID=                                   # REQUIRED
R2_SECRET_ACCESS_KEY=                               # REQUIRED
R2_BUCKET_NAME=cinema-media
R2_PUBLIC_URL=https://media.cinema.growthengine.ai

# ─── AI Models (consolidated via fal.ai — ONE key covers 14+ services) ────────
FAL_API_KEY=                                        # REQUIRED: register at fal.ai

# ─── Anthropic (Claude — orchestration + LLM) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                        # REQUIRED

# ─── Runway (camera control — direct) ────────────────────────────────────────
RUNWAY_API_KEY=                                     # Optional

# ─── xAI (Grok Imagine Video + Grok text) ─────────────────────────────────────
XAI_API_KEY=                                        # Optional

# ─── Audio ───────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=                                 # Optional
ELEVENLABS_DEFAULT_VOICE_ID=                        # Optional
ELEVENLABS_MODEL_ID=eleven_multilingual_v2          # Optional
SUNO_API_KEY=                                       # Optional

# ─── Location & Stock (free tier) ────────────────────────────────────────────
MAPILLARY_ACCESS_TOKEN=                             # Optional
CESIUM_ION_TOKEN=                                   # Optional
PEXELS_API_KEY=                                     # Optional
NOMINATIM_USER_AGENT=CinematicForge/1.0

# ─── Stripe (Stripe-only, PayPal removed) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                       # REQUIRED
STRIPE_WEBHOOK_SECRET=whsec_...                     # REQUIRED
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...           # REQUIRED

# Stripe Subscription Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_YEARLY=
STRIPE_PRICE_ULTIMATE_MONTHLY=
STRIPE_PRICE_ULTIMATE_YEARLY=

# Public price IDs for signup flow
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_STUDIO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_STUDIO_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_ULTIMATE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ULTIMATE_YEARLY=

# Stripe Credit Pack Price IDs (one-time payments)
STRIPE_PRICE_CREDITS_STARTER=                       # 200 credits
STRIPE_PRICE_CREDITS_STANDARD=                      # 600 credits
STRIPE_PRICE_CREDITS_PRO=                           # 1,500 credits
STRIPE_PRICE_CREDITS_PROF=                          # 4,000 credits

# ─── DAS (Direct Attached Storage) ───────────────────────────────────────────
DAS_BASE_PATH=/mnt/das/cinema
DAS_TRAINING_PATH=/data/training
DAS_MOUNT_HOST=

# ─── Hollywood Pipeline (Python microservices) ────────────────────────────────
OTIO_SERVICE_URL=http://localhost:7432
IMF_SERVICE_URL=http://localhost:7433
SHOTGRID_SERVICE_URL=http://localhost:7434
EXR_SERVICE_URL=http://localhost:7435
OSC_LISTEN_PORT=7436

# ─── Third-party integrations ─────────────────────────────────────────────────
FRAMEIO_CLIENT_ID=
FRAMEIO_CLIENT_SECRET=
FRAMEIO_TOKEN=
SHOTGRID_SITE_URL=
SHOTGRID_SCRIPT_NAME=
SHOTGRID_SCRIPT_KEY=

# ─── Email (review portal notifications) ─────────────────────────────────────
RESEND_API_KEY=
REVIEW_EMAIL_FROM=reviews@cinematicforge.ai

# ─── Social Publishing ────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ─── Training cluster (optional — for Growth Engine distillation) ─────────────
TRAINING_CLUSTER_HOST=
TRAINING_CLUSTER_API_KEY=

# ─── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# ─── Cron & Workers ───────────────────────────────────────────────────────────
CRON_SECRET=                                        # REQUIRED for cron routes
WORKER_HEALTH_TOKEN=                                # REQUIRED for worker health checks

# ─── Dev Account ──────────────────────────────────────────────────────────────
DEV_ACCOUNT_EMAIL=innovative.trailers@gmail.com
