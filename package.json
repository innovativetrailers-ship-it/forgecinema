{
  "name": "cinema",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"bash scripts/start_services.sh --wait\"",
    "build": "next build",
    "postinstall": "node scripts/prisma-generate.mjs",
    "deploy:vercel": "bash scripts/deploy-vercel.sh",
    "env:vercel": "bash scripts/sync-vercel-env.sh",
    "start": "next start",
    "lint": "eslint",
    "worker:render": "tsx src/lib/queue/workers/render.worker.ts",
    "worker:training": "tsx src/lib/queue/workers/training.worker.ts",
    "worker:export": "tsx src/lib/queue/workers/export.worker.ts",
    "worker:das": "tsx src/workers/das-pull.ts",
    "worker:intelligence": "tsx src/workers/intelligence-cron.ts",
    "worker:training-pipeline": "tsx src/workers/training-pipeline.ts",
    "worker:quality-gate": "tsx src/workers/quality-gate.ts",
    "worker:distillation": "tsx src/workers/distillation.ts",
    "workers": "concurrently \"npm run worker:render\" \"npm run worker:training\" \"npm run worker:export\" \"npm run worker:das\" \"npm run worker:intelligence\"",
    "db:seed": "npx prisma db seed",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "dev:next": "next dev",
    "services": "bash scripts/start_services.sh",
    "services:install": "bash scripts/install-python-services.sh",
    "services:check": "bash scripts/check-services.sh",
    "workers:docker": "docker compose -f docker-compose.yml -f docker-compose.workers.yml --profile workers --profile python up"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs"
          }
        }
      ]
    },
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.ts",
      "<rootDir>/tests/unit/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/lib/**/*.ts",
      "!src/lib/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 40
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@base-ui/react": "^1.4.1",
    "@fal-ai/client": "^1.10.0",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@remotion/bundler": "^4.0.457",
    "@remotion/renderer": "^4.0.457",
    "@runwayml/sdk": "^3.21.1",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.7.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xml2js": "^0.4.14",
    "@use-gesture/react": "^10.3.1",
    "adm-zip": "^0.5.17",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.76.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "immer": "^11.1.6",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "multer": "^2.1.1",
    "music-metadata": "^11.12.3",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^6.38.0",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.457",
    "shadcn": "^4.6.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "playwright": "^1.59.1",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
